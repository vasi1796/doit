# =============================================================================
# DoIt — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Domain & TLS
# -----------------------------------------------------------------------------
# The public domain for the application (used by Caddy for TLS).
# Use "localhost" for local development.
DOMAIN=localhost

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=doit
POSTGRES_PASSWORD=changeme
POSTGRES_DB=doit

# Full DSN — typically constructed in docker-compose.yml; override here if
# connecting to an external database.
# DATABASE_URL=postgres://doit:changeme@postgres:5432/doit?sslmode=disable

# -----------------------------------------------------------------------------
# Go API
# -----------------------------------------------------------------------------
PORT=8080

# Logging: debug | info | warn | error
LOG_LEVEL=info
# Logging format: json | console (console is human-readable for local dev)
LOG_FORMAT=console

# -----------------------------------------------------------------------------
# Auth — Google OAuth 2.0
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=https://localhost/auth/google/callback

# JWT signing key — generate with: openssl rand -base64 32
JWT_SECRET=

# JWT token lifetime in hours
JWT_EXPIRY_HOURS=72

# Comma-separated list of allowed Google email addresses
ALLOWED_EMAILS=user@example.com

# Set to true for local dev (enables /auth/dev endpoint)
DEV_MODE=false

# URL to redirect to after successful auth
FRONTEND_URL=/

# Set to false for local dev without HTTPS
SECURE_COOKIES=true

# -----------------------------------------------------------------------------
# Database Connection Pool
# -----------------------------------------------------------------------------
# API server pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m


# -----------------------------------------------------------------------------
# Graceful Shutdown
# -----------------------------------------------------------------------------
SHUTDOWN_TIMEOUT=15s

# -----------------------------------------------------------------------------
# RabbitMQ
# -----------------------------------------------------------------------------
RABBITMQ_USER=doit
RABBITMQ_PASSWORD=changeme
RABBITMQ_URL=amqp://doit:changeme@rabbitmq:5672/

# -----------------------------------------------------------------------------
# Web Push Notifications (optional)
# -----------------------------------------------------------------------------
# Generate keys with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# Reminder worker settings
REMINDER_HOUR=8
REMINDER_TZ=UTC

# -----------------------------------------------------------------------------
# Backup
# -----------------------------------------------------------------------------
# Directory where local backups are stored before uploading
BACKUP_DIR=/var/backups/doit

# Number of daily backups to retain
BACKUP_RETAIN_DAILY=7

# Number of weekly backups to retain
BACKUP_RETAIN_WEEKLY=4


# -----------------------------------------------------------------------------
# Monitoring (optional)
# -----------------------------------------------------------------------------
# Set to "true" to enable the /metrics Prometheus endpoint
METRICS_ENABLED=true
