{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/api/cmd/api",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DATABASE_URL": "postgres://doit:changeme@localhost:5432/doit?sslmode=disable"
      }
    },
    {
      "name": "Migrate Up",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/api/cmd/migrate",
      "args": ["up"],
      "cwd": "${workspaceFolder}/api",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "DATABASE_URL": "postgres://doit:changeme@localhost:5432/doit?sslmode=disable"
      }
    },
    {
      "name": "Integration Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/api/internal/eventstore",
      "buildFlags": "-tags=integration",
      "env": {
        "TEST_DATABASE_URL": "postgres://doit:changeme@localhost:5432/doit?sslmode=disable"
      }
    }
  ]
}
